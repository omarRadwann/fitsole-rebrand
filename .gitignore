# Local preview state (the rest of .claude/ — agents/settings — is tracked
# because it's part of the agent OS that ships with the repo)
.claude/launch.json
.claude/cache/
.claude/sessions/
.claude/local/
.vscode/
.idea/
.DS_Store

# Python cache
**/__pycache__/
*.pyc

# Blender working files + third-party + backups
blender/*.blend
blender/*.blend1
blender/addon.py
blender/*.bak*
blender/*.bak

# Build / deps (not used today, but pre-emptive)
node_modules/
dist/
build/
.cache/

# Logs
*.log

# V7 upgrade audit trail (local diff snapshots from os-upgrade-v7 branch)
upgrade-diffs/

# Local-only tool readiness record (machine-specific paths/versions)
tooling/LOCAL_TOOL_STATUS.md

# Local validation output (machine-specific)
VALIDATION_LOCAL_OUTPUT.txt

# Halo-era root-level Node QA tooling (preserved under .archive/halo-2026-05/)
# Do NOT ignore workspace/*/package.json — those are V6 project packages we track.
/package-lock.json
/package.json

# Archive layer (Halo + Caliper preserved here; keep light artifacts, ignore heavy)
.archive/halo-2026-05/node_modules/
.archive/halo-2026-05/.tmp-lighthouse-profile/
.archive/halo-2026-05/upgrade-diffs/

# Next.js / Node build artifacts inside workspaces
workspace/**/.next/
workspace/**/node_modules/
workspace/**/.turbo/
workspace/**/dist/
workspace/**/build/

# Playwright artifacts
**/test-results/
**/playwright-report/
**/.playwright/
