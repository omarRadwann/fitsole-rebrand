{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "ROOT=\"$(git rev-parse --show-toplevel 2>/dev/null || pwd)\"; bash \"$ROOT/.agents/skills/award-website-os/scripts/tool-readiness-check.sh\"",
            "timeout": 60,
            "statusMessage": "Checking Award Website OS readiness"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "apply_patch|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "ROOT=\"$(git rev-parse --show-toplevel 2>/dev/null || pwd)\"; bash \"$ROOT/.agents/skills/award-website-os/scripts/zero-gap-preflight.sh\"",
            "timeout": 180,
            "statusMessage": "Running zero-gap preflight"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "ROOT=\"$(git rev-parse --show-toplevel 2>/dev/null || pwd)\"; bash \"$ROOT/.agents/skills/award-website-os/scripts/final-smart-check.sh\"",
            "timeout": 600,
            "statusMessage": "Running final smart check"
          }
        ]
      }
    ]
  }
}
